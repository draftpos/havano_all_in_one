<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_hide_standalone_multi_uom" model="ir.ui.view">
        <field name="name">product.template.form.hide.standalone.multi.uom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="allow_multi_uom.product_template_form_view_uom_prices"/>
        <field name="priority" eval="55"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='uom_id']/following-sibling::group[1]" position="replace"/>
            <field name="uom_id" position="attributes">
                <attribute name="column_invisible">not parent.allow_multi_uom</attribute>
            </field>
            <field name="uom_barcode" position="attributes">
                <attribute name="column_invisible">not parent.allow_multi_uom</attribute>
            </field>
        </field>
    </record>
</odoo>
