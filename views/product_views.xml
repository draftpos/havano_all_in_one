<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_havano_item_code" model="ir.ui.view">
        <field name="name">product.template.form.havano.item.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">ITEM CODE</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_tree_view_havano_item_code" model="ir.ui.view">
        <field name="name">product.template.tree.havano.item.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="string">ITEM CODE</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_havano_all_in_one_uom_prices" model="ir.ui.view">
        <field name="name">product.template.form.havano.all.in.one.uom.prices</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority" eval="60"/>
        <field name="arch" type="xml">
            <page name="sales" position="after">
                <page string="Others" name="hao_others">
                    <group string="Multi UoM Settings" col="2">
                        <field name="allow_multi_uom" string="Enable Multi UoM Pricing"/>
                        <field name="strict_uom_tracking"
                               string="Allow Strict UoM Tracking on Sales Lines"
                               invisible="not allow_multi_uom"/>
                    </group>
                </page>
            </page>
        </field>
    </record>

    <record id="product_template_form_view_havano_pharmacy" model="ir.ui.view">
        <field name="name">product.template.form.havano.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority" eval="20"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']/span[@name='sale_option']" position="after">
                <field name="hao_activate_pharmacy" invisible="1"/>
                <span name="pharmacy_option" class="d-inline-flex" invisible="not hao_activate_pharmacy">
                    <field name="is_pharmacy"/>
                    <label for="is_pharmacy" string="Is Pharmacy"/>
                </span>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_havano_inventory_orders" model="ir.ui.view">
        <field name="name">product.template.form.havano.inventory.orders</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.view_template_property_form"/>
        <field name="priority" eval="25"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']//field[@name='description_pickingout']/parent::group" position="after">
                <group string="Orders Section"
                       name="hao_orders_section"
                       invisible="not hao_activate_inventory_orders">
                    <field name="hao_activate_inventory_orders" invisible="1"/>
                    <field name="order_1" string="Order 1"/>
                    <field name="order_2" string="Order 2"/>
                    <field name="order_3" string="Order 3"/>
                    <field name="order_4" string="Order 4"/>
                    <field name="order_5" string="Order 5"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_havano_invoice_policy_layout" model="ir.ui.view">
        <field name="name">product.template.form.havano.invoice.policy.layout</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="sale.product_template_form_view"/>
        <field name="priority" eval="70"/>
        <field name="arch" type="xml">
            <field name="invoice_policy" position="replace">
                <label for="invoice_policy"
                       string="Invoicing Policy"
                       invisible="not sale_ok or type == 'combo'"/>
                <div class="o_row"
                     invisible="not sale_ok or type == 'combo'">
                    <field name="invoice_policy" nolabel="1" required="1"/>
                </div>
            </field>
        </field>
    </record>

    <record id="action_hao_open_duplicate_product" model="ir.actions.act_window">
        <field name="name">Duplicate Product</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('id', 'in', active_ids)]</field>
    </record>
</odoo>
