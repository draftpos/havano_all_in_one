<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_view_form_havano_all_in_one" model="ir.ui.view">
        <field name="name">sale.order.form.havano.all.in.one</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="context">{'from_sale_order': True}</attribute>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_view_form_havano_all_in_one" model="ir.ui.view">
        <field name="name">purchase.order.form.havano.all.in.one</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="context">{'from_purchase_order': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
