<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pharmacy_dosage_list" model="ir.ui.view">
        <field name="name">pharmacy.dosage.list</field>
        <field name="model">pharmacy.dosage</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_dosage_form" model="ir.ui.view">
        <field name="name">pharmacy.dosage.form</field>
        <field name="model">pharmacy.dosage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Dosage description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pharmacy_dosage" model="ir.actions.act_window">
        <field name="name">Dosages</field>
        <field name="res_model">pharmacy.dosage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pharmacy_dosage"
              name="Dosages"
              parent="stock.menu_product_in_config_stock"
              action="action_pharmacy_dosage"
              sequence="45"
              groups="stock.group_stock_user"/>
</odoo>
