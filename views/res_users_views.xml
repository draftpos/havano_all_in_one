<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_havano_all_in_one" model="ir.ui.view">
        <field name="name">res.users.form.inherit.havano.all.in.one</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']//field[@name='role']" position="after">
                <field name="hao_activate_pharmacy" invisible="1"/>
                <label for="is_pharmacist" string="Additional roles" invisible="share or not hao_activate_pharmacy"/>
                <div class="o_row" invisible="share or not hao_activate_pharmacy">
                    <field name="is_pharmacist" nolabel="1"/>
                    <label for="is_pharmacist" string="Pharmacist"/>
                    <field name="is_cashier" nolabel="1" class="ms-3"/>
                    <label for="is_cashier" string="Cashier"/>
                </div>
                <div class="text-muted" invisible="share or not hao_activate_pharmacy">
                    Pharmacist and Cashier are additional roles on top of User
                    or Administrator (for example User + Pharmacist, or
                    Administrator + Cashier).
                </div>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Havano Automation">
                    <group string="Sales and Invoice Automation">
                        <field name="hao_enable_sales_automation"/>
                        <field name="hao_sales_automation_method" invisible="not hao_enable_sales_automation"/>
                        <field name="hao_auto_confirm_quotation" invisible="not hao_enable_sales_automation or hao_sales_automation_method != 'full'"/>
                        <field name="hao_auto_create_invoice" invisible="not hao_enable_sales_automation or hao_sales_automation_method != 'full'"/>
                        <field name="hao_auto_post_invoice" invisible="not hao_enable_sales_automation or hao_sales_automation_method != 'full'"/>
                    </group>
                    <group string="Purchase Automation">
                        <field name="hao_enable_purchase_automation"/>
                        <field name="hao_purchase_automation_method" invisible="not hao_enable_purchase_automation"/>
                        <field name="hao_auto_confirm_purchase" invisible="not hao_enable_purchase_automation or hao_purchase_automation_method != 'full'"/>
                        <field name="hao_auto_validate_receipt" invisible="not hao_enable_purchase_automation or hao_purchase_automation_method != 'full'"/>
                        <field name="hao_auto_create_vendor_bill" invisible="not hao_enable_purchase_automation or hao_purchase_automation_method != 'full'"/>
                        <field name="hao_auto_post_vendor_bill" invisible="not hao_enable_purchase_automation or hao_purchase_automation_method != 'full'"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
