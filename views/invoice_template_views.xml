<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_havano_invoice_template_tree" model="ir.ui.view">
        <field name="name">havano.invoice.template.tree</field>
        <field name="model">havano.invoice.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="is_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_havano_invoice_template_form" model="ir.ui.view">
        <field name="name">havano.invoice.template.form</field>
        <field name="model">havano.invoice.template</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_apply_layout" type="object" string="Apply Layout" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="row">
                        <div class="col-12 col-md-5">
                            <group>
                                <field name="name"/>
                                <field name="base_layout" widget="selection_badge"/>
                            </group>
                            <group string="Colors">
                                <field name="base_color" widget="color"/>
                                <field name="heading_text_color" widget="color"/>
                                <field name="text_color" widget="color"/>
                                <field name="customer_text_color" widget="color"/>
                                <field name="company_text_color" widget="color"/>
                            </group>
                            <group string="Positions">
                                <field name="logo_position"/>
                                <field name="tagline_position"/>
                                <field name="customer_position"/>
                                <field name="company_position"/>
                            </group>
                            <group string="Display Options">
                                <field name="sales_person"/>
                                <field name="description"/>
                                <field name="tax_value"/>
                                <field name="reference"/>
                                <field name="source"/>
                                <field name="address"/>
                                <field name="city"/>
                                <field name="country"/>
                                <field name="vat"/>
                            </group>
                        </div>
                        <div class="col-12 col-md-7">
                            <field name="preview" widget="html" nolabel="1" readonly="1"/>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_havano_invoice_template" model="ir.actions.act_window">
        <field name="name">Invoice Templates</field>
        <field name="res_model">havano.invoice.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
