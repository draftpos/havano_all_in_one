<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_pricelist_item_form_view_inherit_uom" model="ir.ui.view">
        <field name="name">product.pricelist.item.form.inherit.uom</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[1]" position="inside">
                <separator string="Multi UoM Details"/>
                <label for="uom_id" string="Unit of Measure" class="fw-bold"/>
                <field name="uom_id"/>
                <label for="uom_barcode" string="UoM Barcode" class="fw-bold"/>
                <field name="uom_barcode"/>
            </xpath>
        </field>
    </record>

    <record id="product_pricelist_item_tree_view_inherit_uom" model="ir.ui.view">
        <field name="name">product.pricelist.item.tree.inherit.uom</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[1]" position="before">
                <field name="uom_id" optional="show"/>
                <field name="uom_barcode" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_uom_pricelist_columns" model="ir.ui.view">
        <field name="name">product.template.form.uom.pricelist.columns</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority" eval="55"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="after">
                <page string="Other" name="other_settings">
                    <group string="Multi UoM Settings" name="multi_uom_settings" col="2">
                        <field name="allow_multi_uom" string="Enable Multi UoM Pricing"/>
                        <field name="strict_uom_tracking"
                               string="Allow Strict UoM Tracking on Sales Lines"
                               invisible="not allow_multi_uom"/>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='pricelist_rule_ids']/list" position="inside">
                <field name="uom_id" optional="show" column_invisible="not parent.allow_multi_uom"/>
                <field name="uom_barcode" optional="show" column_invisible="not parent.allow_multi_uom"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_inherit_multi_uom_line_editable" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.multi.uom.line.editable</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='product_uom_id']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//form//field[@name='product_uom_id']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
        </field>
    </record>
</odoo>
