<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_stock_pharmacy" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.stock.pharmacy</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='stock']" position="inside">
                <block title="Pharmacy" name="hao_pharmacy_setting">
                    <setting string="Activate Pharmacy" help="Enable pharmacy products, dosages, and doctor contacts.">
                        <field name="hao_activate_pharmacy"/>
                    </setting>
                </block>
                <block title="Inventory Order Settings" name="hao_inventory_orders_setting">
                    <setting string="Activate Inventory Order Settings"
                               help="Show Order 1–5 checkboxes on each product Inventory tab and in the POS API.">
                        <field name="hao_activate_inventory_orders"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
